# --- Dependencies -----------------------------------------------------------
node_modules/

# --- Vite build output ------------------------------------------------------
# We commit a placeholder dist/index.html so `go build .` works on a fresh
# clone without Node installed (see web/embed.go). Everything else under
# dist/ — hashed assets, the real built index.html, etc. — is regenerated
# by `npm run build` and shouldn't be in version control.
dist/*
!dist/index.html

# --- TypeScript -------------------------------------------------------------
*.tsbuildinfo

# --- Vite cache -------------------------------------------------------------
.vite/
.vite-cache/

# --- Logs -------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Local env / secrets ----------------------------------------------------
.env
.env.local
.env.*.local
*.local

# --- Test artifacts ---------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# --- Editor / IDE -----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# --- OS junk ----------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
